{
  "name": "captura-partidos-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "build:render": "node ./node_modules/prisma/build/index.js generate && node ./node_modules/prisma/build/index.js db push",
    "start:render": "node ./node_modules/prisma/build/index.js generate && node ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate-rbac": "tsx prisma/migrate-rbac.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "pdfkit": "^0.15.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "@fastify/multipart": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pdfkit": "^0.13.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
