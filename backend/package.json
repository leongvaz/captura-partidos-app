{
  "name": "captura-partidos-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node ./node_modules/prisma/build/index.js generate",
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "prestart": "prisma generate",
    "start": "node dist/index.js",
    "fix:esbuild": "npm rebuild esbuild",
    "build:render": "prisma migrate deploy && prisma generate && npm run fix:esbuild && tsc",
    "start:render": "prisma generate && npm run fix:esbuild && node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-anotadores-pruebas": "tsx prisma/seed-anotadores-pruebas.ts",
    "db:migrate-rbac": "tsx prisma/migrate-rbac.ts",
    "db:backfill-historial": "tsx src/scripts/backfill_persona_resumenes.ts",
    "db:backfill-sedes": "tsx src/scripts/backfill_sedes_canchas.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.13.0",
    "embedded-postgres": "^18.3.0-beta.17",
    "typescript": "^5.6.3"
  }
}
