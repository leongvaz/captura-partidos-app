generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Identidad estable de la competencia (varias temporadas bajo la misma liga)
model Liga {
  id           String          @id @default(uuid())
  nombre       String
  deporte      String          @default("baloncesto")
  categorias   String          @default("[\"primera\",\"segunda\",\"veteranos\",\"femenil\",\"varonil\"]")
  reglasConfig String          @default("{}")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  temporadas   Temporada[]
  membresias   MembresiaLiga[]
  equipos      Equipo[]
  sedes        Sede[]
  canchas      Cancha[]
  partidos     Partido[]
  invitaciones Invitacion[]
}

// Ciclo competitivo (año, apertura/clausura, etc.)
model Temporada {
  id        String   @id @default(uuid())
  ligaId    String
  etiqueta  String
  fechaInicio DateTime?
  fechaFin  DateTime?
  estado    String   @default("activa") // activa | archivada
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  liga      Liga     @relation(fields: [ligaId], references: [id], onDelete: Cascade)
  equipos   Equipo[]
  partidos  Partido[]

  @@index([ligaId])
  @@index([ligaId, estado])
}

model Sede {
  id        String   @id @default(uuid())
  ligaId    String
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  liga      Liga     @relation(fields: [ligaId], references: [id], onDelete: Cascade)
  canchas   Cancha[]

  @@index([ligaId])
}

// Identidad deportiva única por CURP (historial cruzando ligas/temporadas/deportes)
model Persona {
  id                     String   @id @default(uuid())
  curp                   String   @unique
  nombreDisplay          String?
  apellidoDisplay        String?
  sexo                   String?
  fechaNacimiento        String?
  solicitudEliminacionAt DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  jugadores              Jugador[]
  resumenesPartido       ResumenJugadorPartido[]
}

model Usuario {
  id           String          @id @default(uuid())
  nombre       String
  curp         String?
  pinHash      String?
  email        String?
  passwordHash String?
  isSuperAdmin Boolean         @default(false)
  activo       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  membresias   MembresiaLiga[]
  partidos     Partido[]       @relation("PartidosAnotados")
  equiposDueno Equipo[]        @relation("EquiposPorDueno")

  @@unique([curp])
}

model MembresiaLiga {
  id        String   @id @default(uuid())
  ligaId    String
  usuarioId String
  rol       String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  liga      Liga     @relation(fields: [ligaId], references: [id], onDelete: Cascade)
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([ligaId, usuarioId, rol])
  @@index([ligaId])
  @@index([usuarioId])
}

model Equipo {
  id                String             @id @default(uuid())
  ligaId            String
  temporadaId       String
  duenoId           String?
  nombre            String
  categoria         String
  activo            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  liga              Liga               @relation(fields: [ligaId], references: [id], onDelete: Cascade)
  temporada         Temporada          @relation(fields: [temporadaId], references: [id], onDelete: Restrict)
  dueno             Usuario?           @relation("EquiposPorDueno", fields: [duenoId], references: [id], onDelete: SetNull)
  jugadores         Jugador[]
  partidosLocal     Partido[]          @relation("Local")
  partidosVisitante Partido[]          @relation("Visitante")
  plantillas        PlantillaPartido[]
  incidencias       Incidencia[]
  resumenesJugador  ResumenJugadorPartido[]

  @@index([duenoId])
  @@index([ligaId])
  @@index([temporadaId])
}

model Jugador {
  id              String   @id @default(uuid())
  equipoId        String
  personaId       String?
  nombre          String
  apellido        String
  numero          Int
  curp            String?
  sexo            String?
  fechaNacimiento String?
  fotoUrl         String?
  invitado        Boolean  @default(false)
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  equipo          Equipo   @relation(fields: [equipoId], references: [id], onDelete: Restrict)
  persona         Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  plantillas      PlantillaPartido[]
  eventos         Evento[] @relation("JugadorEvento")
  eventosEntra    Evento[] @relation("JugadorEntra")
  incidencias     Incidencia[]
  resumenesPartido ResumenJugadorPartido[]

  @@unique([equipoId, numero])
  @@index([curp])
  @@index([personaId])
}

model Cancha {
  id        String    @id @default(uuid())
  ligaId    String
  sedeId    String?
  nombre    String
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  liga      Liga      @relation(fields: [ligaId], references: [id], onDelete: Cascade)
  sede      Sede?     @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  partidos  Partido[]

  @@index([sedeId])
}

model Partido {
  id                     String             @id
  ligaId                 String
  temporadaId            String
  localEquipoId          String
  visitanteEquipoId      String
  canchaId               String
  categoria              String
  fecha                  String
  horaInicio             String
  estado                 String             @default("programado")
  folio                  String?            @unique
  anotadorId             String
  marcadorLocalFinal     Int?
  marcadorVisitanteFinal Int?
  fotoMarcadorUrl        String?
  fotosOpcionales        String?            @default("[]")
  cerradoAt              DateTime?
  localVersion           Int                @default(1)
  serverVersion          Int                @default(1)
  lastSyncedAt           DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  liga                   Liga               @relation(fields: [ligaId], references: [id], onDelete: Cascade)
  temporada              Temporada          @relation(fields: [temporadaId], references: [id], onDelete: Restrict)
  localEquipo            Equipo             @relation("Local", fields: [localEquipoId], references: [id])
  visitanteEquipo        Equipo             @relation("Visitante", fields: [visitanteEquipoId], references: [id])
  cancha                 Cancha             @relation(fields: [canchaId], references: [id])
  anotador               Usuario            @relation("PartidosAnotados", fields: [anotadorId], references: [id])
  plantilla              PlantillaPartido[]
  eventos                Evento[]
  incidencias            Incidencia[]
  cierrePartido          CierrePartido?
  resumenesJugador       ResumenJugadorPartido[]

  @@index([ligaId])
  @@index([temporadaId])
}

model CierrePartido {
  id              String   @id @default(uuid())
  partidoId       String   @unique
  clientClosureId String   @unique
  createdAt       DateTime @default(now())
  partido         Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
}

model PlantillaPartido {
  id              String   @id @default(uuid())
  partidoId       String
  equipoId        String
  jugadorId       String
  enCanchaInicial Boolean  @default(false)
  esCapitan       Boolean  @default(false)
  esCoach         Boolean  @default(false)
  invitado        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  partido         Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  equipo          Equipo   @relation(fields: [equipoId], references: [id])
  jugador         Jugador  @relation(fields: [jugadorId], references: [id], onDelete: Restrict)

  @@unique([partidoId, jugadorId])
}

model Evento {
  id                      String    @id
  partidoId               String
  tipo                    String
  jugadorId               String
  jugadorEntraId          String?
  minutoPartido           Float
  cuarto                  Int
  orden                   Int
  segundosRestantesCuarto Int?
  tiempoPartidoSegundos   Int?
  createdAt               DateTime  @default(now())
  serverReceivedAt        DateTime?
  partido                 Partido   @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador                 Jugador   @relation("JugadorEvento", fields: [jugadorId], references: [id], onDelete: Restrict)
  jugadorEntra            Jugador?  @relation("JugadorEntra", fields: [jugadorEntraId], references: [id], onDelete: SetNull)
}

model Incidencia {
  id        String   @id @default(uuid())
  partidoId String
  tipo      String
  equipoId  String?
  jugadorId String?
  motivo    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partido   Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  equipo    Equipo?  @relation(fields: [equipoId], references: [id])
  jugador   Jugador? @relation(fields: [jugadorId], references: [id])
}

model ResumenJugadorPartido {
  id                  String   @id @default(uuid())
  partidoId           String
  jugadorId           String
  personaId           String?
  equipoId            String
  puntos              Int      @default(0)
  canastasDe2         Int      @default(0)
  canastasDe3         Int      @default(0)
  tirosLibresAnotados Int      @default(0)
  faltas              Int      @default(0)
  asistencias         Int      @default(0)
  minutosJugados      Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  partido             Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador             Jugador  @relation(fields: [jugadorId], references: [id], onDelete: Restrict)
  persona             Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  equipo              Equipo   @relation(fields: [equipoId], references: [id], onDelete: Restrict)

  @@unique([partidoId, jugadorId])
  @@index([personaId])
  @@index([jugadorId])
  @@index([partidoId])
}

model Invitacion {
  id        String   @id @default(uuid())
  token     String   @unique
  tipo      String
  ligaId    String
  usado     Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  liga Liga @relation(fields: [ligaId], references: [id], onDelete: Cascade)

  @@index([ligaId])
}
